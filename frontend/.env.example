# Leave empty in development to use Vite proxy (recommended).
# In production, set to your backend URL (no trailing slash), e.g. https://api.yourdomain.com
VITE_API_URL=

# Optional: WebSocket URL. Defaults to VITE_API_URL or current origin.
# Set in production if socket is on a different host, e.g. https://api.yourdomain.com
VITE_SOCKET_URL=
