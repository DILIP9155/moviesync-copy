# Server (default 5001 to avoid conflict with macOS AirPlay on 5000)
PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://dilipkumar23_db_user:i8L9cQ7nK7hfN5Uj@cluster0.78l8ab4.mongodb.net/moveinsync_tracking

# CORS (comma-separated for multiple in production)
CORS_ORIGIN=http://localhost:5173

# JWT (required for auth; use a long random string in production)
JWT_SECRET="hexacode"
JWT_EXPIRES_IN=7d

# Geofence
GEOFENCE_MIN_DWELL_SECONDS=30
OFFICE_SPEED_THRESHOLD_KMH=10

# Location streaming: devices should POST to /api/locations/stream every 5–10 seconds
LOCATION_STREAM_INTERVAL_MS=5000

# Optional: Map (e.g. for geocoding or custom tiles)
# MAPBOX_ACCESS_TOKEN=pk.xxx

# Optional: SMS (Twilio) for pickup arrival notifications
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE=+1234567890

# Optional: Push notifications (FCM)
# FCM_SERVER_KEY=xxx
